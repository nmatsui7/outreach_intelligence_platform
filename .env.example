# Copy this file to .env and adjust paths for your machine.
# AI_PROVIDER=mock | local_llm | openai
AI_PROVIDER=mock

# Local LLM settings (only needed in local_llm mode)
LLAMA_SERVER_URL=http://127.0.0.1:8082
MODEL_PATH=/path/to/your/model.gguf
LLAMA_PORT=8082
LLAMA_CTX_SIZE=8192
LLAMA_THREADS=6
LLAMA_TIMEOUT=120
