# Copy this file to .env and adjust paths for your machine.
# AI_PROVIDER=mock | local_llm | openai
AI_PROVIDER=mock

# Local LLM settings (only needed in local_llm mode)
LLAMA_PORT=8082
LLAMA_BIN=/usr/local/bin/llama-server
MODEL_PATH=/path/to/your/model.gguf
CHAT_TEMPLATE=gemma4_official.jinja
LLAMA_CTX_SIZE=8192
LLAMA_THREADS=6
LLAMA_MODEL=gemma-4-E4B-it
LLAMA_TIMEOUT=180
